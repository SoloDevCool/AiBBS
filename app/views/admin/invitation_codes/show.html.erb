<%= link_to admin_invitation_codes_path, class: "text-decoration-none mb-3 d-inline-block" do %>
  <i class="bi bi-arrow-left me-1"></i>返回邀请码列表
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="text-dark fw-bold mb-0">邀请码详情</h4>
  <span class="badge bg-light text-dark rounded-pill px-3 py-2" style="font-size:1rem;letter-spacing:0.12em;font-weight:600"><%= @invitation_code.code %></span>
</div>

<!-- 邀请码信息 -->
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card card-admin text-center p-3">
      <div class="text-muted small mb-1">状态</div>
      <div>
        <% if !@invitation_code.enabled? %>
          <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">已禁用</span>
        <% elsif @invitation_code.expired? %>
          <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">已过期</span>
        <% elsif !@invitation_code.usable? %>
          <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill">已用完</span>
        <% else %>
          <span class="badge bg-success bg-opacity-10 text-success rounded-pill">可用</span>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card card-admin text-center p-3">
      <div class="text-muted small mb-1">已使用</div>
      <div class="fw-bold fs-5">
        <% if @invitation_code.max_uses.nil? %>
          <%= @invitation_code.used_count %> 次
        <% else %>
          <%= @invitation_code.used_count %>/<%= @invitation_code.max_uses %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card card-admin text-center p-3">
      <div class="text-muted small mb-1">过期时间</div>
      <div class="fw-bold">
        <% if @invitation_code.expires_at %>
          <%= @invitation_code.expires_at.strftime("%Y-%m-%d %H:%M") %>
        <% else %>
          <span class="text-muted">永不过期</span>
        <% end %>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card card-admin text-center p-3">
      <div class="text-muted small mb-1">创建者</div>
      <div class="fw-bold"><%= @invitation_code.created_by.display_name %></div>
    </div>
  </div>
</div>

<!-- 使用该邀请码注册的用户 -->
<div class="card card-admin">
  <div class="card-header py-3 d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>使用用户</h6>
    <span class="badge bg-light text-dark rounded-pill"><%= @invitation_code.users.count %> 人</span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-3">#</th>
            <th>邮箱</th>
            <th>用户名</th>
            <th class="d-none d-md-table-cell">角色</th>
            <th class="d-none d-lg-table-cell">注册时间</th>
          </tr>
        </thead>
        <tbody>
          <% @invitation_code.users.each_with_index do |user, index| %>
            <tr>
              <td class="ps-3 text-muted"><%= index + 1 %></td>
              <td><%= user.email %></td>
              <td><%= user.display_name %></td>
              <td class="d-none d-md-table-cell">
                <span class="badge <%= user.admin? ? 'bg-warning text-dark' : 'bg-secondary bg-opacity-10 text-secondary' %> rounded-pill">
                  <%= user.role_label %>
                </span>
              </td>
              <td class="d-none d-lg-table-cell text-muted"><small><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></small></td>
            </tr>
          <% end %>
          <% if @invitation_code.users.empty? %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">暂无用户使用此邀请码</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
