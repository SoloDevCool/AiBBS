<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="text-dark fw-bold mb-0">邀请码管理</h4>
  <span class="badge bg-light text-dark rounded-pill px-3 py-2">
    共 <%= InvitationCode.count %> 个邀请码
    &middot; 可用 <%= InvitationCode.active.count %> 个
  </span>
</div>

<!-- 生成邀请码 -->
<div class="card card-admin mb-4">
  <div class="card-header py-3">
    <h6 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>生成邀请码</h6>
  </div>
  <div class="card-body">
    <%= form_with url: admin_invitation_codes_path, method: :post, class: "row g-3 align-items-end" do |f| %>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">生成数量</label>
        <input type="number" name="count" value="1" min="1" max="100" class="form-control form-control-sm">
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">最大使用次数</label>
        <input type="number" name="max_uses" value="1" min="1" class="form-control form-control-sm" placeholder="1">
        <div class="form-text">留空不限制</div>
      </div>
      <div class="col-md-3">
        <label class="form-label fw-semibold small">过期时间</label>
        <input type="datetime-local" name="expires_at" class="form-control form-control-sm">
        <div class="form-text">留空永不过期</div>
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary btn-sm w-100" data-confirm="确定生成邀请码吗？">
          <i class="bi bi-plus-lg me-1"></i>生成
        </button>
      </div>
    <% end %>
  </div>
</div>

<!-- 邀请码列表 -->
<div class="card card-admin">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-3">邀请码</th>
            <th>状态</th>
            <th>使用情况</th>
            <th class="d-none d-md-table-cell">创建者</th>
            <th class="d-none d-lg-table-cell">过期时间</th>
            <th class="d-none d-lg-table-cell">创建时间</th>
            <th class="pe-3 text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @invitation_codes.each do |code| %>
            <tr>
              <td class="ps-3">
                <code class="text-decoration-none" style="font-size:0.9rem;letter-spacing:0.08em" onclick="navigator.clipboard.writeText('<%= code.code %>').then(()=>{this.classList.add('text-success');setTimeout(()=>this.classList.remove('text-success'),1000)})" title="点击复制"><%= code.code %></code>
                <i class="bi bi-clipboard text-muted ms-1" style="font-size:0.75rem"></i>
              </td>
              <td>
                <% if !code.enabled? %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">已禁用</span>
                <% elsif code.expired? %>
                  <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill">已过期</span>
                <% elsif !code.usable? %>
                  <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill">已用完</span>
                <% else %>
                  <span class="badge bg-success bg-opacity-10 text-success rounded-pill">可用</span>
                <% end %>
              </td>
              <td>
                <% if code.max_uses.nil? %>
                  <span class="text-muted"><%= code.used_count %> 次使用</span>
                <% else %>
                  <span><%= code.used_count %>/<%= code.max_uses %></span>
                  <div class="progress mt-1" style="height:4px;width:60px">
                    <div class="progress-bar bg-<%= code.used_count >= code.max_uses ? 'danger' : 'primary' %>" style="width:<%= [code.used_count.to_f / code.max_uses * 100, 100].min %>%"></div>
                  </div>
                <% end %>
              </td>
              <td class="d-none d-md-table-cell text-muted"><small><%= code.created_by.display_name %></small></td>
              <td class="d-none d-lg-table-cell text-muted"><small><%= code.expires_at ? code.expires_at.strftime("%Y-%m-%d %H:%M") : "永不过期" %></small></td>
              <td class="d-none d-lg-table-cell text-muted"><small><%= code.created_at.strftime("%Y-%m-%d %H:%M") %></small></td>
              <td class="pe-3 text-end">
                <div class="d-flex gap-1 justify-content-end">
                  <%= link_to admin_invitation_code_path(code), class: "btn btn-sm btn-outline-primary btn-action", title: "查看使用详情" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                  <%= button_to admin_invitation_code_path(code), method: :delete, class: "btn btn-sm btn-outline-danger btn-action", title: "删除", data: { confirm: "确定删除邀请码 #{code.code} 吗？" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @invitation_codes.empty? %>
            <tr>
              <td colspan="7" class="text-center text-muted py-4">暂无邀请码，请先生成</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% if @pagy.last > 1 %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center mb-0">
      <% if @pagy.previous %>
        <li class="page-item">
          <%= link_to raw('<i class="bi bi-chevron-left"></i>'), admin_invitation_codes_path(page: @pagy.previous), class: "page-link rounded" %>
        </li>
      <% end %>
      <% @pagy.series.each do |item| %>
        <% if item.is_a?(Integer) %>
          <li class="page-item <%= item == @pagy.page ? 'active' : '' %>">
            <%= link_to item, admin_invitation_codes_path(page: item), class: "page-link rounded" %>
          </li>
        <% elsif item == :gap %>
          <li class="page-item disabled"><span class="page-link">...</span></li>
        <% end %>
      <% end %>
      <% if @pagy.next %>
        <li class="page-item">
          <%= link_to raw('<i class="bi bi-chevron-right"></i>'), admin_invitation_codes_path(page: @pagy.next), class: "page-link rounded" %>
        </li>
      <% end %>
    </ul>
  </nav>
<% end %>
