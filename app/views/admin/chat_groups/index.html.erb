<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="text-dark fw-bold mb-0">交流群管理</h4>
  <div class="d-flex gap-2 align-items-center">
    <div class="form-check form-switch mb-0">
      <input class="form-check-input" type="checkbox" role="switch" id="chatGroupsToggle"
        <%= SiteSetting.get("chat_groups_enabled", default: "false") == "true" ? "checked" : "" %>
        style="cursor:pointer">
      <label class="form-check-label" for="chatGroupsToggle" style="font-size:0.85rem">
        前台显示
      </label>
    </div>
    <%= link_to new_admin_chat_group_path, class: "btn btn-primary rounded-pill px-3" do %>
      <i class="bi bi-plus-lg me-1"></i>新建交流群
    <% end %>
  </div>
</div>

<div class="card card-admin">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-3">交流群</th>
            <th class="text-center">分类</th>
            <th class="text-center">人数</th>
            <th class="text-center d-none d-sm-table-cell">状态</th>
            <th class="text-center d-none d-md-table-cell">排序</th>
            <th class="pe-3 text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @chat_groups.each do |group| %>
            <tr>
              <td class="ps-3">
                <div class="d-flex align-items-center">
                  <% if group.logo.attached? %>
                    <div class="rounded-2 me-2 flex-shrink-0 overflow-hidden" style="width:36px;height:36px">
                      <img src="<%= url_for(group.logo.variant(resize_to_fill: [72, 72])) %>" class="w-100 h-100" style="object-fit:cover" alt="">
                    </div>
                  <% else %>
                    <div class="rounded-2 bg-primary bg-opacity-10 me-2 flex-shrink-0 d-flex align-items-center justify-content-center" style="width:36px;height:36px">
                      <i class="bi bi-people text-primary" style="font-size:0.9rem"></i>
                    </div>
                  <% end %>
                  <div>
                    <div class="fw-semibold"><%= group.name %></div>
                    <% if group.description.present? %>
                      <small class="text-muted"><%= truncate(group.description, length: 30) %></small>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark rounded-pill" style="font-size:0.75rem">
                  <%= group.category_label %>
                </span>
              </td>
              <td class="text-center">
                <span class="badge bg-light text-dark rounded-pill"><%= group.members_count %></span>
              </td>
              <td class="text-center d-none d-sm-table-cell">
                <span class="badge <%= group.is_active? ? 'bg-success' : 'bg-secondary' %> rounded-pill" style="font-size:0.75rem">
                  <%= group.is_active? ? '显示' : '隐藏' %>
                </span>
              </td>
              <td class="text-center d-none d-md-table-cell">
                <span class="text-muted"><%= group.sort_order %></span>
              </td>
              <td class="pe-3 text-end">
                <div class="d-flex justify-content-end gap-1">
                  <%= link_to edit_admin_chat_group_path(group), class: "btn-action btn btn-sm btn-outline-primary border-0" do %>
                    <i class="bi bi-pencil"></i>
                  <% end %>
                  <%= button_to admin_chat_group_path(group), method: :delete,
                      class: "btn-action btn btn-sm btn-outline-danger border-0",
                      data: { confirm: "确定删除交流群「#{group.name}」吗？" } do %>
                    <i class="bi bi-trash"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @chat_groups.empty? %>
            <tr>
              <td colspan="6" class="text-center text-muted py-5">
                <i class="bi bi-inbox d-block mb-2" style="font-size:2rem"></i>
                暂无交流群，点击上方按钮创建
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
document.getElementById('chatGroupsToggle').addEventListener('change', function() {
  var enabled = this.checked ? 'true' : 'false';
  var token = document.querySelector('meta[name="csrf-token"]').content;
  fetch('<%= admin_settings_path %>', {
    method: 'PATCH',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': token
    },
    body: JSON.stringify({ settings: { chat_groups_enabled: enabled } })
  })
  .then(function(res) { return res.json ? res : res.text(); })
  .then(function() {
    var label = enabled === 'true' ? '已开启交流群功能' : '已关闭交流群功能';
    var alertDiv = document.createElement('div');
    alertDiv.className = 'alert alert-success alert-dismissible fade show py-2';
    alertDiv.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999;min-width:200px';
    alertDiv.innerHTML = label + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    document.body.appendChild(alertDiv);
    setTimeout(function() { alertDiv.remove(); }, 2000);
  });
});
</script>
