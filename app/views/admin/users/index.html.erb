<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="text-dark fw-bold mb-0">用户管理</h4>
  <span class="badge bg-light text-dark rounded-pill px-3 py-2"><%= User.real_users.count %> 位真实用户</span>
</div>

<div class="card card-admin">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead>
          <tr>
            <th class="ps-3">#</th>
            <th>邮箱</th>
            <th class="d-none d-md-table-cell">当前角色</th>
            <th class="d-none d-lg-table-cell">注册时间</th>
            <th class="pe-3 text-end">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each_with_index do |user, index| %>
            <tr id="user-<%= user.id %>">
              <td class="ps-3 text-muted"><%= @pagy.offset + index + 1 %></td>
              <td>
                <div class="d-flex align-items-center">
                  <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:34px;height:34px;font-size:0.85rem">
                    <i class="bi bi-person-fill"></i>
                  </div>
                  <div>
                    <div><%= user.email %></div>
                    <% if user == current_user %>
                      <small class="text-muted">当前用户</small>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="d-none d-md-table-cell">
                <span class="badge <%= user.admin? ? 'bg-warning text-dark' : 'bg-secondary bg-opacity-10 text-secondary' %> rounded-pill">
                  <%= user.role_label %>
                </span>
              </td>
              <td class="d-none d-lg-table-cell text-muted"><small><%= user.created_at.strftime("%Y-%m-%d %H:%M") %></small></td>
              <td class="pe-3 text-end">
                <% unless user == current_user %>
                  <%= button_to admin_user_path(user), method: :patch,
                      params: { role: user.admin? ? "user" : "admin" },
                      class: user.admin? ? "btn btn-sm btn-outline-info rounded-pill px-3" : "btn btn-sm btn-outline-warning rounded-pill px-3",
                      data: { confirm: "确定要将 #{user.email} 的角色修改为#{user.admin? ? '普通用户' : '管理员'}吗？" } do %>
                    <i class="bi bi-arrow-repeat me-1"></i><%= user.admin? ? "设为用户" : "设为管理" %>
                  <% end %>
                <% else %>
                  <span class="text-muted small">-</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% if @pagy.last > 1 %>
  <nav class="mt-3">
    <ul class="pagination justify-content-center mb-0">
      <% if @pagy.previous %>
        <li class="page-item">
          <%= link_to raw('<i class="bi bi-chevron-left"></i>'), admin_users_path(page: @pagy.previous), class: "page-link rounded" %>
        </li>
      <% end %>
      <% @pagy.series.each do |item| %>
        <% if item.is_a?(Integer) %>
          <li class="page-item <%= item == @pagy.page ? 'active' : '' %>">
            <%= link_to item, admin_users_path(page: item), class: "page-link rounded" %>
          </li>
        <% elsif item == :gap %>
          <li class="page-item disabled"><span class="page-link">...</span></li>
        <% end %>
      <% end %>
      <% if @pagy.next %>
        <li class="page-item">
          <%= link_to raw('<i class="bi bi-chevron-right"></i>'), admin_users_path(page: @pagy.next), class: "page-link rounded" %>
        </li>
      <% end %>
    </ul>
  </nav>
<% end %>
