<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "管理控制台 - SoloDev.Cool" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SoloDev.Cool Admin">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <% if site_favicon_url %>
      <link rel="icon" href="<%= site_favicon_url %>" type="image/png">
    <% else %>
      <link rel="icon" href="/icon.png" type="image/png">
    <% end %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
      body { background-color: #f4f6f9; }
      .sidebar { min-height: 100vh; width: 260px; position: fixed; top: 0; left: 0; z-index: 1000; transition: transform 0.3s ease; }
      .sidebar .nav-link { color: rgba(255,255,255,.7); border-radius: 0.375rem; margin-bottom: 2px; font-size: 0.9rem; }
      .sidebar .nav-link:hover { color: #fff; background: rgba(255,255,255,.1); }
      .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.15); font-weight: 600; }
      .sidebar .nav-link i { width: 22px; text-align: center; }
      .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 999; }
      .sidebar-overlay.show { display: block; }
      .main-content { margin-left: 260px; min-height: 100vh; }
      .stat-card { border: none; border-radius: 12px; transition: transform 0.2s; }
      .stat-card:hover { transform: translateY(-2px); }
      .stat-card .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; }
      .card-admin { border: none; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
      .card-admin .card-header { background: #fff; border-bottom: 1px solid #eee; border-radius: 12px 12px 0 0 !important; }
      .table th { font-size: 0.8rem; text-transform: uppercase; letter-spacing: .5px; color: #6c757d; font-weight: 600; border-bottom-width: 1px; }
      .table td { vertical-align: middle; font-size: 0.9rem; }
      .btn-action { width: 34px; height: 34px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; }
      @media (max-width: 991.98px) {
        .sidebar { transform: translateX(-100%); }
        .sidebar.show { transform: translateX(0); }
        .main-content { margin-left: 0; }
      }
    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <div class="sidebar bg-dark" id="adminSidebar">
      <div class="p-3 border-bottom border-secondary">
        <a href="/" class="text-white text-decoration-none d-flex align-items-center">
          <% if site_logo_url %>
            <img src="<%= site_logo_url %>" alt="Logo" style="max-height: 28px; max-width: 160px; object-fit: contain;">
          <% else %>
            <i class="bi bi-terminal fs-4 me-2"></i>
            <span class="fs-5 fw-bold">SoloDev.Cool</span>
          <% end %>
        </a>
        <div class="text-white-50 mt-1" style="font-size:0.75rem">管理控制台</div>
      </div>
      <nav class="nav flex-column p-3 mt-1">
        <%= link_to admin_root_path, class: "nav-link #{current_page?(admin_root_path) ? 'active' : ''}" do %>
          <i class="bi bi-grid-1x2 me-2"></i>仪表盘
        <% end %>
        <%= link_to admin_users_path, class: "nav-link #{controller_name == 'users' ? 'active' : ''}" do %>
          <i class="bi bi-people me-2"></i>用户管理
        <% end %>
        <%= link_to admin_operational_accounts_path, class: "nav-link #{controller_name == 'operational_accounts' ? 'active' : ''}" do %>
          <i class="bi bi-person-badge me-2"></i>运营账号
        <% end %>
        <%= link_to admin_nodes_path, class: "nav-link #{controller_name == 'nodes' ? 'active' : ''}" do %>
          <i class="bi bi-diagram-3 me-2"></i>节点管理
        <% end %>
        <%= link_to admin_chat_groups_path, class: "nav-link #{controller_name == 'chat_groups' ? 'active' : ''}" do %>
          <i class="bi bi-people me-2"></i>交流群管理
        <% end %>
        <%= link_to admin_friend_links_path, class: "nav-link #{controller_name == 'friend_links' ? 'active' : ''}" do %>
          <i class="bi bi-link-45deg me-2"></i>友链管理
        <% end %>
        <%= link_to admin_invitation_codes_path, class: "nav-link #{controller_name == 'invitation_codes' ? 'active' : ''}" do %>
          <i class="bi bi-key me-2"></i>邀请码管理
        <% end %>
        <%= link_to admin_settings_path, class: "nav-link #{controller_name == 'settings' ? 'active' : ''}" do %>
          <i class="bi bi-gear me-2"></i>系统设置
        <% end %>
        <%= link_to admin_seo_settings_path, class: "nav-link #{controller_name == 'seo_settings' ? 'active' : ''}" do %>
          <i class="bi bi-search me-2"></i>SEO 设置
        <% end %>
        <%= link_to admin_appearance_settings_path, class: "nav-link #{controller_name == 'appearance_settings' ? 'active' : ''}" do %>
          <i class="bi bi-palette me-2"></i>外观设置
        <% end %>
      </nav>
      <div class="position-absolute bottom-0 w-100 p-3 border-top border-secondary">
        <a href="/" class="nav-link"><i class="bi bi-arrow-left me-2"></i>返回前台</a>
      </div>
    </div>

    <!-- Mobile Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Top Bar -->
      <nav class="navbar navbar-light bg-white shadow-sm px-3 px-lg-4">
        <button class="btn btn-link text-dark d-lg-none p-0 me-2" id="sidebarToggle">
          <i class="bi bi-list fs-4"></i>
        </button>
        <span class="navbar-text text-muted" style="font-size:0.85rem">
          <i class="bi bi-shield-check me-1"></i>管理员：<%= current_user.email %>
        </span>
      </nav>

      <div class="p-3 p-lg-4">
        <% if notice %>
          <div class="alert alert-success alert-dismissible fade show py-2" role="alert"><%= notice %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        <% end %>
        <% if alert %>
          <div class="alert alert-danger alert-dismissible fade show py-2" role="alert"><%= alert %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        <% end %>

        <%= yield %>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        const toggle = document.getElementById('sidebarToggle');
        if (toggle) {
          toggle.addEventListener('click', () => { sidebar.classList.add('show'); overlay.classList.add('show'); });
          overlay.addEventListener('click', () => { sidebar.classList.remove('show'); overlay.classList.remove('show'); });
        }
      });
    </script>
  </body>
</html>
