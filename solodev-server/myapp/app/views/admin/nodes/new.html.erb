<h4 class="text-dark fw-bold mb-4">新建节点</h4>

<div class="card card-admin" style="max-width:640px">
  <div class="card-body p-4">
    <%= form_with model: [:admin, @node], local: true do |f| %>
      <% if @node.errors.any? %>
        <div class="alert alert-danger rounded-3 py-2">
          <i class="bi bi-exclamation-circle me-1"></i>
          <ul class="mb-0 ms-3">
            <% @node.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-3">
        <%= f.label :name, "节点名称", class: "form-label fw-semibold small text-muted" %>
        <%= f.text_field :name, class: "form-control form-control-lg rounded-3", placeholder: "例如：技术分享" %>
        <div class="form-text">显示给用户的名称</div>
      </div>

      <div class="mb-3">
        <%= f.label :slug, "Slug 标识", class: "form-label fw-semibold small text-muted" %>
        <%= f.text_field :slug, class: "form-control form-control-lg rounded-3", placeholder: "例如：tech-share" %>
        <div class="form-text">URL 中使用的唯一标识，只能包含小写字母、数字、横线和下划线</div>
      </div>

      <div class="mb-3">
        <%= f.label :kind, "节点类型", class: "form-label fw-semibold small text-muted" %>
        <div class="d-flex gap-3 mt-1">
          <% Node.kinds_i18n.each do |value, label| %>
            <div class="form-check">
              <%= f.radio_button :kind, value, class: "form-check-input", id: "node_kind_#{value}", data: { kind: value } %>
              <label class="form-check-label" for="node_kind_<%= value %>">
                <span class="badge <%= value == 'system' ? 'bg-primary bg-opacity-10 text-primary' : 'bg-success bg-opacity-10 text-success' %> rounded-pill">
                  <%= label %>
                </span>
              </label>
            </div>
          <% end %>
        </div>
        <div class="form-text mt-1">系统节点为社区内置分类，兴趣节点为用户自定义兴趣领域</div>
      </div>

      <div class="mb-3" id="position-field" style="display:none">
        <%= f.label :position, "排序位置", class: "form-label fw-semibold small text-muted" %>
        <%= f.number_field :position, class: "form-control form-control-lg rounded-3", min: 0, value: 0 %>
        <div class="form-text">数值越小越靠前，系统节点支持拖拽排序</div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', function() {
          const kindInputs = document.querySelectorAll('input[name="node[kind]"]');
          const positionField = document.getElementById('position-field');

          kindInputs.forEach(input => {
            input.addEventListener('change', function() {
              if (this.dataset.kind === 'system') {
                positionField.style.display = 'block';
              } else {
                positionField.style.display = 'none';
              }
            });
          });

          // 初始化显示状态
          const checkedInput = document.querySelector('input[name="node[kind]"]:checked');
          if (checkedInput && checkedInput.dataset.kind === 'system') {
            positionField.style.display = 'block';
          }
        });
      </script>

      <div class="mb-3">
        <%= f.label :icon, "图标", class: "form-label fw-semibold small text-muted" %>
        <%= f.text_field :icon, class: "form-control form-control-lg rounded-3", placeholder: "例如：💻", maxlength: 10 %>
        <div class="form-text">支持 Emoji 或文字，最多 10 个字符</div>
      </div>

      <div class="mb-4">
        <%= f.label :description, "描述", class: "form-label fw-semibold small text-muted" %>
        <%= f.text_area :description, class: "form-control rounded-3", rows: 3, placeholder: "节点的简要描述..." %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "创建节点", class: "btn btn-primary rounded-pill px-4" %>
        <%= link_to "取消", admin_nodes_path, class: "btn btn-outline-secondary rounded-pill px-4" %>
      </div>
    <% end %>
  </div>
</div>
