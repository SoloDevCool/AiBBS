<h4 class="mb-4 text-dark fw-bold">仪表盘</h4>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center">
        <div class="stat-icon bg-primary bg-opacity-10 text-primary me-3">
          <i class="bi bi-people-fill"></i>
        </div>
        <div>
          <div class="text-muted small">总用户</div>
          <div class="fs-4 fw-bold mb-0"><%= @total_users %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center">
        <div class="stat-icon bg-warning bg-opacity-10 text-warning me-3">
          <i class="bi bi-shield-fill-check"></i>
        </div>
        <div>
          <div class="text-muted small">管理员</div>
          <div class="fs-4 fw-bold mb-0"><%= @admin_count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center">
        <div class="stat-icon bg-info bg-opacity-10 text-info me-3">
          <i class="bi bi-person-fill"></i>
        </div>
        <div>
          <div class="text-muted small">普通用户</div>
          <div class="fs-4 fw-bold mb-0"><%= @regular_count %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center">
        <div class="stat-icon bg-success bg-opacity-10 text-success me-3">
          <i class="bi bi-diagram-3-fill"></i>
        </div>
        <div>
          <div class="text-muted small">节点数</div>
          <div class="fs-4 fw-bold mb-0"><%= Node.count %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Recent Users -->
  <div class="col-lg-7">
    <div class="card card-admin">
      <div class="card-header d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>最近注册用户</h6>
        <%= link_to admin_users_path, class: "btn btn-sm btn-outline-primary rounded-pill px-3" do %>
          查看全部<i class="bi bi-arrow-right ms-1"></i>
        <% end %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th class="ps-3">邮箱</th>
                <th>角色</th>
                <th class="pe-3 text-end">注册时间</th>
              </tr>
            </thead>
            <tbody>
              <% @recent_users.each do |user| %>
                <tr>
                  <td class="ps-3">
                    <div class="d-flex align-items-center">
                      <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center me-2" style="width:32px;height:32px;font-size:0.8rem">
                        <i class="bi bi-person-fill"></i>
                      </div>
                      <%= user.email %>
                    </div>
                  </td>
                  <td>
                    <span class="badge <%= user.admin? ? 'bg-warning text-dark' : 'bg-secondary bg-opacity-10 text-secondary' %> rounded-pill">
                      <%= user.role_label %>
                    </span>
                  </td>
                  <td class="pe-3 text-end text-muted"><small><%= user.created_at.strftime("%m-%d %H:%M") %></small></td>
                </tr>
              <% end %>
              <% if @recent_users.empty? %>
                <tr><td colspan="3" class="text-center text-muted py-4">暂无用户</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Nodes List -->
  <div class="col-lg-5">
    <div class="card card-admin">
      <div class="card-header d-flex justify-content-between align-items-center py-3">
        <h6 class="mb-0 fw-bold"><i class="bi bi-diagram-3 me-2 text-success"></i>节点列表</h6>
        <%= link_to admin_nodes_path, class: "btn btn-sm btn-outline-success rounded-pill px-3" do %>
          管理<i class="bi bi-arrow-right ms-1"></i>
        <% end %>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th class="ps-3">节点</th>
                <th class="text-center">主题</th>
                <th class="pe-3 text-end">操作</th>
              </tr>
            </thead>
            <tbody>
              <% Node.order(id: :asc).limit(8).each do |node| %>
                <tr>
                  <td class="ps-3">
                    <div class="d-flex align-items-center">
                      <span class="me-2" style="font-size:1.2rem"><%= node.icon.presence || "📄" %></span>
                      <div>
                        <div class="fw-semibold"><%= node.name %></div>
                        <small class="text-muted"><%= node.slug %></small>
                      </div>
                    </div>
                  </td>
                  <td class="text-center">
                    <span class="badge bg-light text-dark"><%= node.topics_count %></span>
                  </td>
                  <td class="pe-3 text-end">
                    <%= link_to edit_admin_node_path(node), class: "btn-action btn btn-sm btn-outline-primary border-0" do %>
                      <i class="bi bi-pencil"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
              <% if Node.count == 0 %>
                <tr><td colspan="3" class="text-center text-muted py-4">暂无节点</td></tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
