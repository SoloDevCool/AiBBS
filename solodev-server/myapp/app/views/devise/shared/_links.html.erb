<div class="mt-3">
  <%- if controller_name != 'sessions' %>
    <%= link_to "登录", new_session_path(resource_name), class: "btn btn-outline-secondary w-100" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "注册", new_registration_path(resource_name), class: "btn btn-outline-primary w-100 mt-2" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "忘记密码?", new_password_path(resource_name), class: "d-block mt-2 text-center" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "未收到确认邮件?", new_confirmation_path(resource_name), class: "d-block mt-2 text-center" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "未收到解锁邮件?", new_unlock_path(resource_name), class: "d-block mt-2 text-center" %>
  <% end %>
</div>
