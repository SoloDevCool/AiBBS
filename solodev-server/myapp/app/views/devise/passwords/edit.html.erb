<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="text-center mb-4">重置密码</h2>
          <p class="text-center text-muted mb-4" style="font-size:0.9rem">请输入您的新密码</p>

          <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "needs-validation" }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>
            <%= f.hidden_field :reset_password_token %>

            <div class="mb-3">
              <%= f.label :password, "新密码", class: "form-label" %>
              <% if @minimum_password_length %>
                <small class="text-muted">（至少 <%= @minimum_password_length %> 个字符）</small>
              <% end %>
              <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control", placeholder: "请输入新密码" %>
            </div>

            <div class="mb-3">
              <%= f.label :password_confirmation, "确认新密码", class: "form-label" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "请再次输入新密码" %>
            </div>

            <div class="d-grid">
              <%= f.submit "重置密码", class: "btn btn-primary" %>
            </div>
          <% end %>

          <hr>
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
