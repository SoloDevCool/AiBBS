<% content_for :title, "#{@topic.title} - SoloDev.Cool" %>
<% content_for :head do %>
  <%= seo_meta_tags(title: "#{@topic.title} - SoloDev.Cool", description: @topic.content.truncate(160), keywords: @topic.node&.name, url: topic_url(@topic), type: "article") %>
  <%= json_ld_breadcrumb([{ name: "首页", url: root_url }, { name: "社区", url: topics_url }, { name: @topic.title, url: topic_url(@topic) }]) %>
  <%= json_ld_article(@topic) %>
  <meta name="robots" content="index, follow">
  <script src="https://cdn.jsdelivr.net/npm/qrcode-generator@1.4.4/qrcode.min.js"></script>
<% end %>

<div class="container-lg py-3">
  <div class="row g-3">

    <!-- 左侧节点列表 -->
    <div class="col-lg-2 left-sidebar">
      <div class="node-list">
        <a href="<%= topics_path %>" class="node-item">
          <span class="node-icon"><i class="bi bi-grid"></i></span>
          <span>全部</span>
          <span class="node-count"><%= Topic.count %></span>
        </a>
        <% {"system" => "system", "interest" => "interest"}.each do |order_key, kind| %>
          <% nodes = @all_nodes.select { |n| n.kind == kind } %>
          <% next if nodes.empty? %>
          <h6 class="d-flex align-items-center justify-content-between text-muted mb-1 mt-3 ps-2" style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.5px;">
            <span>
              <i class="bi <%= kind == 'system' ? 'bi-gear' : 'bi-star' %> me-1"></i><%= Node.kinds_i18n[kind.to_sym] %>
            </span>
            <% if kind == "interest" %>
              <%= link_to topics_path(kind: kind), class: "text-decoration-none text-muted", style: "font-size:0.7rem; text-transform:none; letter-spacing:0" do %>全部<% end %>
            <% end %>
          </h6>
          <% if kind == "interest" %>
            <% if user_signed_in? %>
              <% if @sidebar_followed_nodes.present? %>
                <% @sidebar_followed_nodes.each do |node| %>
                  <a href="<%= node_topics_path(node) %>" class="node-item <%= node == @topic.node ? 'active' : '' %>">
                    <span class="node-icon"><%= node.icon.presence || "📄" %></span>
                    <span><%= node.name %></span>
                    <span class="node-count"><%= node.topics_count %></span>
                  </a>
                <% end %>
              <% else %>
                <div class="text-muted text-center py-2" style="font-size:0.78rem">
                  <a href="<%= topics_path(kind: 'interest') %>" class="text-decoration-none">去发现节点</a>
                </div>
              <% end %>
            <% else %>
              <div class="text-muted text-center py-2" style="font-size:0.78rem">
                <a href="<%= new_user_session_path %>" class="text-decoration-none">登录后查看</a>
              </div>
            <% end %>
          <% else %>
            <% nodes.each do |node| %>
              <a href="<%= node_topics_path(node) %>" class="node-item <%= node == @topic.node ? 'active' : '' %>">
                <span class="node-icon"><%= node.icon.presence || "📄" %></span>
                <span><%= node.name %></span>
                <span class="node-count"><%= node.topics_count %></span>
              </a>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- 中间：主题内容 -->
    <div class="col-lg-7">
      <div class="bg-white rounded shadow-sm overflow-hidden">
        <!-- 顶部导航 -->
        <div class="d-flex align-items-center border-bottom px-3 py-2">
          <% back_url = if request.referer&.include?("/nodes/") && request.referer&.include?("/topics")
                          node_topics_path(@topic.node)
                        else
                          topics_path
                        end %>
          <%= link_to back_url, class: "btn btn-sm btn-outline-secondary me-2" do %>
            <i class="bi bi-arrow-left me-1"></i>返回
          <% end %>
          <%= link_to node_topics_path(@topic.node), class: "btn btn-sm btn-outline-primary text-truncate" do %>
            <%= @topic.node.icon %> <%= @topic.node.name %>
          <% end %>
          <button type="button" class="btn btn-sm btn-outline-primary ms-2" onclick="generatePoster()" title="生成长图">
            <i class="bi bi-image me-1"></i>长图
          </button>
          <% if can_manage_topic?(@topic) || current_user&.admin? %>
            <div class="ms-auto d-flex gap-1">
              <% if current_user&.admin? %>
                <% if @topic.pinned? %>
                  <%= button_to unpin_topic_path(@topic), method: :post, class: "btn btn-sm btn-outline-warning rounded-pill px-2",
                      data: { confirm: "确定取消置顶？" } do %>
                    <i class="bi bi-pin-angle me-1"></i>取消置顶
                  <% end %>
                <% else %>
                  <%= button_to pin_topic_path(@topic), method: :post, class: "btn btn-sm btn-outline-warning rounded-pill px-2",
                      data: { confirm: "确定置顶此主题？" } do %>
                    <i class="bi bi-pin-angle-fill me-1"></i>置顶
                  <% end %>
                <% end %>
              <% end %>
              <% if can_manage_topic?(@topic) %>
                <%= link_to edit_topic_path(@topic), class: "btn btn-sm btn-outline-secondary rounded-pill px-2" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to topic_path(@topic.id), method: :delete, class: "btn btn-sm btn-outline-danger rounded-pill px-2",
                    data: { confirm: "确定删除此主题吗？" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- 主题详情 -->
        <div class="p-4">
          <h5 class="fw-bold mb-3"><%= @topic.title %></h5>

          <% if @topic.pinned? %>
            <div class="alert alert-warning py-2 px-3 mb-3 d-flex align-items-center" style="font-size:0.82rem">
              <i class="bi bi-pin-angle-fill me-2"></i>该主题已被管理员置顶
            </div>
          <% end %>

          <!-- 作者信息 -->
          <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
            <% user_link = @topic.user == current_user ? profile_path : (@topic.user.profile_public? ? user_path(@topic.user) : nil) %>
            <% tag = user_link ? :a : :div %>
            <% link_opts = user_link ? { href: user_link, class: "d-flex align-items-center text-decoration-none flex-grow-1" } : { class: "d-flex align-items-center flex-grow-1", data: { bs_toggle: "popover", bs_placement: "top", bs_content: "该用户已设置隐私，主页不公开", bs_trigger: "focus click" }, tabindex: "0", role: "button" } %>
            <%= content_tag tag, **link_opts do %>
              <% if @topic.user.has_avatar? %>
                <div class="rounded-3 me-2 flex-shrink-0 overflow-hidden" style="width:36px;height:36px">
                  <img src="<%= @topic.user.avatar_data_url %>" class="w-100 h-100" style="object-fit:cover" alt="">
                </div>
              <% else %>
                <div class="rounded-3 bg-avatar-<%= @topic.user.id % 5 + 1 %> d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:36px;height:36px;color:#fff;font-weight:600;font-size:0.85rem">
                  <%= user_initial(@topic.user) %>
                </div>
              <% end %>
              <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2">
                  <span class="fw-semibold" style="font-size:0.9rem;color:var(--text-primary)"><%= @topic.user.display_name %></span>
                  <span class="badge bg-light text-secondary rounded-pill" style="font-size:0.7rem">
                    <i class="bi bi-people me-1"></i><%= @topic.user.followers.count %>
                  </span>
                </div>
                <div class="text-muted" style="font-size:0.78rem">
                  <%= @topic.created_at.strftime("%Y-%m-%d %H:%M") %> &middot;
                  <i class="bi bi-eye me-1"></i><%= @topic.views_count %> 次浏览 &middot;
                  <i class="bi bi-chat-dots me-1"></i><%= @comments.count %> 条评论 &middot;
                  <i class="bi bi-snow me-1"></i><%= @topic.cools_count %> cool
                </div>
              </div>
            <% end %>
            <% if user_signed_in? && current_user != @topic.user %>
              <% if @topic.user.blocked?(current_user) %>
                <%= button_to unblock_user_path(@topic.user), method: :delete, class: "btn btn-sm btn-outline-secondary rounded-pill px-3 flex-shrink-0" do %>
                  <i class="bi bi-unlock me-1"></i>取消屏蔽
                <% end %>
              <% elsif @topic.user.followed_by?(current_user) %>
                <%= button_to unfollow_user_path(@topic.user), method: :delete, class: "btn btn-sm btn-outline-secondary rounded-pill px-3 flex-shrink-0" do %>
                  <i class="bi bi-person-check me-1"></i>已关注
                <% end %>
              <% else %>
                <%= button_to follow_user_path(@topic.user), method: :post, class: "btn btn-sm btn-primary rounded-pill px-3 flex-shrink-0" do %>
                  <i class="bi bi-person-plus me-1"></i>关注
                <% end %>
              <% end %>
            <% end %>
          </div>

          <!-- 投票区域 -->
          <% if @poll.present? %>
            <div class="poll-section mb-3 p-3 rounded-3 border" id="poll-section">
              <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart-line me-2 text-primary"></i>投票</h6>
                <div class="d-flex align-items-center gap-2">
                  <span class="text-muted small"><i class="bi bi-people me-1"></i><span id="poll-total-votes"><%= @poll.total_votes %></span> 人参与</span>
                  <% if can_manage_topic?(@topic) %>
                    <% if @poll.closed? %>
                      <%= button_to open_topic_poll_path(@topic), method: :post, class: "btn btn-sm btn-outline-success rounded-pill px-2", style: "font-size:0.72rem" do %>
                        <i class="bi bi-play-circle me-1"></i>开启
                      <% end %>
                    <% else %>
                      <%= button_to close_topic_poll_path(@topic), method: :post, class: "btn btn-sm btn-outline-secondary rounded-pill px-2", style: "font-size:0.72rem" do %>
                        <i class="bi bi-stop-circle me-1"></i>关闭
                      <% end %>
                      <%= button_to topic_poll_path(@topic), method: :delete, class: "btn btn-sm btn-outline-danger rounded-pill px-2", style: "font-size:0.72rem", data: { confirm: "确定删除投票？" } do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              </div>
              <% if @poll.closed? %>
                <div class="alert alert-secondary py-1 px-2 mb-2" style="font-size:0.75rem"><i class="bi bi-lock me-1"></i>投票已结束</div>
              <% end %>
              <div id="poll-options-container">
                <% @poll.poll_options.each_with_index do |option, idx| %>
                  <% voted_option = @poll.voted_option_for(current_user) %>
                  <% has_voted = @poll.voted_by?(current_user) || @poll.closed? %>
                  <div class="poll-option mb-2 <%= has_voted && option == voted_option ? 'poll-option-selected' : '' %>"
                       data-option-id="<%= option.id %>" data-voted="<%= has_voted ? 'true' : 'false' %>"
                       onclick="handlePollVote(this, <%= @topic.id %>, <%= option.id %>)">
                    <div class="poll-option-label">
                      <span class="poll-option-letter"><%= ('A'..'Z').to_a[idx] %></span>
                      <span class="poll-option-title"><%= option.title %></span>
                      <% if has_voted && option == voted_option %>
                        <i class="bi bi-check-circle-fill poll-option-check"></i>
                      <% end %>
                    </div>
                    <% if has_voted %>
                      <div class="poll-option-bar">
                        <div class="poll-option-bar-fill" style="width:<%= option.vote_percentage %>%"></div>
                      </div>
                      <div class="poll-option-meta">
                        <span><%= option.vote_percentage %>%</span>
                        <span><%= option.votes_count %> 票</span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <% if !user_signed_in? %>
                <div class="text-center mt-2">
                  <%= link_to "登录后投票", new_user_session_path, class: "btn btn-sm btn-outline-primary rounded-pill px-3" %>
                </div>
              <% end %>
            </div>
          <% end %>

          <!-- 正文 -->
          <textarea id="topic-content-raw" style="display:none"><%= @topic.content %></textarea>
          <div id="topic-content-rendered" class="markdown-body lh-lg" style="font-size:0.95rem"></div>
        </div>

        <!-- Cool 按钮 -->
        <div class="border-top px-4 py-3 d-flex align-items-center justify-content-between">
          <div class="d-flex align-items-center gap-2">
            <% if @topic.is_repost? && @topic.source_url.present? %>
              <span class="badge bg-warning text-dark" style="font-size:0.72rem;font-weight:500"><i class="bi bi-arrow-repeat me-1"></i>转载</span>
              <%= link_to @topic.source_url, target: "_blank", rel: "noopener noreferrer", class: "text-decoration-none", style: "font-size:0.8rem;color:var(--primary)" do %>
                <i class="bi bi-box-arrow-up-right me-1"></i>查看原文
              <% end %>
            <% else %>
              <span class="badge bg-success" style="font-size:0.72rem;font-weight:500"><i class="bi bi-pen me-1"></i>原创</span>
            <% end %>
          </div>
          <div class="d-flex align-items-center gap-2">
          <% if user_signed_in? && current_user != @topic.user %>
            <button type="button" class="btn btn-sm rounded-pill px-3 cool-btn <%= @topic.cooled_by?(current_user) ? 'cooled' : '' %>" id="cool-btn" data-topic-id="<%= @topic.id %>" data-cooled="<%= @topic.cooled_by?(current_user) ? 'true' : 'false' %>">
              Cool <span id="cools-count"><%= @topic.cools_count %></span>
            </button>
          <% elsif current_user == @topic.user %>
            <span class="text-muted" style="font-size:0.85rem"><i class="bi bi-snow me-1"></i><span id="cools-count"><%= @topic.cools_count %></span> 人觉得很 cool</span>
          <% else %>
            <span class="text-muted" style="font-size:0.85rem"><i class="bi bi-snow me-1"></i><span id="cools-count"><%= @topic.cools_count %></span> cool</span>
          <% end %>
          </div>
        </div>

      </div>

      <!-- 评论区 -->
      <div class="bg-white rounded shadow-sm overflow-hidden mt-3">
        <div class="d-flex align-items-center border-bottom px-3 py-2">
          <i class="bi bi-chat-dots me-2 text-muted"></i>
          <h6 class="mb-0 fw-bold">评论 <span class="text-muted fw-normal" style="font-size:0.8rem">(<%= @comments.count %>)</span></h6>
        </div>

        <!-- 评论列表 -->
        <div class="comment-list">
          <% @comments.each do |comment| %>
            <div class="d-flex gap-2 px-4 py-3 border-bottom">
              <% if comment.user.has_avatar? %>
                <div class="rounded-3 flex-shrink-0 overflow-hidden" style="width:32px;height:32px">
                  <img src="<%= comment.user.avatar_data_url %>" class="w-100 h-100" style="object-fit:cover" alt="">
                </div>
              <% else %>
                <div class="rounded-3 bg-avatar-<%= comment.user.id % 5 + 1 %> d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;color:#fff;font-weight:600;font-size:0.75rem">
                  <%= user_initial(comment.user) %>
                </div>
              <% end %>
              <div class="flex-grow-1">
                <% if comment.login_only && !user_signed_in? %>
                  <div class="d-flex align-items-center gap-2 mb-0">
                    <span class="text-muted fw-semibold" style="font-size:0.85rem"><%= comment.user.display_name %></span>
                    <span class="text-muted" style="font-size:0.72rem"><%= time_ago_in_words(comment.created_at) %>前</span>
                  </div>
                  <div class="text-muted py-2" style="font-size:0.85rem">
                    <i class="bi bi-lock me-1"></i>该评论仅登录用户可见
                    <span class="mx-1">·</span>
                    <%= link_to "登录查看", new_user_session_path, class: "text-decoration-none", style: "color:var(--primary)" %>
                  </div>
                <% else %>
                <% tip_total = Tip.total_amount_for(comment) %>
                <div class="d-flex align-items-center gap-2 mb-1">
                  <%= link_to comment.user == current_user ? profile_path : user_path(comment.user), class: "fw-semibold text-decoration-none", style: "font-size:0.85rem;color:var(--text-primary)" do %>
                    <%= comment.user.display_name %>
                  <% end %>
                  <span class="text-muted" style="font-size:0.72rem"><%= time_ago_in_words(comment.created_at) %>前</span>
                  <div class="ms-auto d-flex gap-2 align-items-center">
                    <% if user_signed_in? && comment.user != current_user %>
                      <button type="button" class="btn btn-link p-0 comment-cool-btn <%= comment.comment_cools.exists?(user: current_user) ? 'cooled' : '' %>"
                        style="font-size:0.72rem" data-comment-id="<%= comment.id %>" data-topic-id="<%= @topic.id %>"
                        data-cooled="<%= comment.comment_cools.exists?(user: current_user) ? 'true' : 'false' %>"
                        data-cools-count="<%= comment.comment_cools.count %>">
                        Cool <span class="comment-cools-count"><%= comment.comment_cools.count %></span>
                      </button>
                    <% else %>
                      <span class="text-muted" style="font-size:0.72rem">Cool <span class="comment-cools-count"><%= comment.comment_cools.count %></span></span>
                    <% end %>
                    <% if user_signed_in? && current_user == @topic.user && comment.user != current_user %>
                      <button type="button" class="btn btn-link text-warning p-0 tip-trigger" style="font-size:0.72rem"
                        data-comment-id="<%= comment.id %>" data-comment-user="<%= comment.user.display_name %>"
                        data-topic-id="<%= @topic.id %>" data-current-points="<%= current_user.points %>"
                        data-tip-total="<%= tip_total || 0 %>">
                        <i class="bi bi-gift me-1"></i>打赏
                      </button>
                    <% end %>
                    <% if user_signed_in? %>
                      <button type="button" class="btn btn-link text-muted p-0" style="font-size:0.72rem" onclick="toggleReplyForm(this)">
                        <i class="bi bi-reply me-1"></i>回复
                      </button>
                    <% end %>
                    <% if comment.user == current_user || current_user&.admin? %>
                      <%= button_to toggle_login_only_topic_comment_path(@topic, comment), method: :post, class: "btn btn-sm btn-link p-0 #{comment.login_only ? 'text-primary' : 'text-muted'}", style: "font-size:0.72rem", title: comment.login_only ? "取消仅登录可见" : "设为仅登录可见" do %>
                        <i class="bi bi-eye-slash"></i>
                      <% end %>
                    <% elsif comment.login_only %>
                      <span class="text-muted" style="font-size:0.72rem" title="仅登录用户可见"><i class="bi bi-eye-slash"></i></span>
                    <% end %>
                    <% if comment.user == current_user || current_user&.admin? %>
                      <%= button_to topic_comment_path(@topic, comment), method: :delete, class: "btn btn-sm btn-link text-muted p-0", style: "font-size:0.72rem" do %>
                        <i class="bi bi-trash"></i>
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <% if comment.parent.present? %>
                  <div class="comment-quote-block mb-2">
                    <div class="comment-quote-header">
                      <span class="text-primary fw-semibold" style="font-size:0.78rem">@<%= comment.parent.user.display_name %></span>
                    </div>
                    <div class="comment-quote-content"><%= truncate(comment.parent.content, length: 150) %></div>
                  </div>
                <% end %>

                <div style="font-size:0.9rem; line-height:1.6"><%= render_mentions(comment.content) %></div>

                <% if comment.login_only && user_signed_in? %>
                  <div class="mt-1" style="font-size:0.72rem;color:var(--text-secondary)">
                    <i class="bi bi-eye-slash me-1"></i>仅登录用户可见
                  </div>
                <% end %>

                <!-- 打赏信息 -->
                <% if tip_total > 0 %>
                  <div class="tip-info mt-1">
                    <span class="tip-badge"><i class="bi bi-gift me-1"></i>已获打赏 <strong><%= tip_total %></strong> 酷能量</span>
                  </div>
                <% end %>

                <!-- 回复表单 -->
                <% if user_signed_in? %>
                  <div class="reply-form mt-2" style="display:none">
                    <%= form_with(model: [@topic, Comment.new], url: topic_comments_path(@topic), local: true, class: "mb-0") do |f| %>
                      <%= f.hidden_field :parent_id, value: comment.id %>
                      <div class="comment-quote-block mb-2">
                        <div class="comment-quote-header">
                          <span class="text-primary fw-semibold" style="font-size:0.78rem">@<%= comment.user.display_name %></span>
                        </div>
                        <div class="comment-quote-content"><%= truncate(comment.content, length: 150) %></div>
                      </div>
                      <div class="mb-2">
                        <%= f.text_area :content, rows: 2, class: "form-control form-control-sm", placeholder: "写下你的回复...", style: "font-size:0.85rem;resize:none" %>
                      </div>
                      <div class="d-flex justify-content-between align-items-center gap-2">
                        <div class="form-check mb-0">
                          <%= f.check_box :login_only, class: "form-check-input", style: "cursor:pointer" %>
                          <label class="form-check-label" style="font-size:0.78rem;cursor:pointer" for="comment_login_only">
                            <i class="bi bi-eye-slash me-1"></i>仅登录可见
                          </label>
                        </div>
                        <div class="d-flex gap-2">
                          <button type="button" class="btn btn-sm btn-light" onclick="cancelReply(this)">取消</button>
                          <%= f.submit "回复", class: "btn btn-primary btn-sm" %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
          <% if @comments.empty? %>
            <div class="text-center text-muted py-5" style="font-size:0.85rem">
              <i class="bi bi-chat-square-text d-block mb-2" style="font-size:1.5rem"></i>
              暂无评论，来说两句吧
            </div>
          <% end %>
        </div>

        <!-- 评论表单 -->
        <% if user_signed_in? %>
          <div class="border-top px-4 py-3">
            <%= form_with(model: [@topic, Comment.new], local: true, class: "mb-0") do |f| %>
              <div class="mb-2">
                <%= f.text_area :content, id: "new-comment-input", rows: 3, class: "form-control form-control-sm", placeholder: "写下你的评论... 使用 @username 提及用户", style: "resize:none" %>
              </div>
              <div class="d-flex justify-content-between align-items-center">
                <div class="form-check mb-0">
                  <%= f.check_box :login_only, class: "form-check-input", style: "cursor:pointer" %>
                  <label class="form-check-label" style="font-size:0.8rem;cursor:pointer" for="comment_login_only">
                    <i class="bi bi-eye-slash me-1"></i>仅登录用户可见
                  </label>
                </div>
                <%= f.submit "发表评论", class: "btn btn-primary btn-sm rounded-pill px-3" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="border-top px-4 py-3 text-center">
            <%= link_to "登录后评论", new_user_session_path, class: "btn btn-sm btn-outline-primary rounded-pill px-3" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 右侧栏 -->
    <div class="col-lg-3 right-sidebar">
      <!-- 用户卡片 -->
      <div class="sidebar-card user-card mb-3">
        <div class="card-header-bg"></div>
        <div class="card-body text-center pb-0">
          <div class="avatar-wrapper">
            <% if user_signed_in? %>
              <%= link_to profile_path, class: "d-block" do %>
                <div class="user-avatar bg-avatar-1">
                  <% if current_user.has_avatar? %>
                    <img src="<%= current_user.avatar_data_url %>" class="rounded-3 w-100 h-100" style="object-fit:cover" alt="头像">
                  <% else %>
                    <%= user_initial(current_user) %>
                  <% end %>
                </div>
              <% end %>
            <% else %>
              <div class="user-avatar bg-avatar-1">
                <i class="bi bi-person" style="font-size:1.5rem"></i>
              </div>
            <% end %>
          </div>
          <div class="user-name">
            <% if user_signed_in? %>
              <%= link_to profile_path, class: "text-decoration-none text-dark" do %>
                <%= current_user.display_name %>
              <% end %>
              <span class="badge <%= current_user.admin? ? 'bg-warning text-dark' : 'bg-info' %> user-role-badge" style="font-size:0.6rem">
                <%= current_user.role_label %>
              </span>
            <% else %>
              游客
            <% end %>
          </div>
          <div class="user-stats-row">
            <div class="user-stat">
              <% if user_signed_in? %>
                <%= link_to topics_path(scope: "mine"), class: "text-decoration-none" do %>
                  <div class="user-stat-value"><%= current_user.topics.count %></div>
                  <div class="user-stat-label">主题</div>
                <% end %>
              <% else %>
                <div class="user-stat-value">0</div>
                <div class="user-stat-label">主题</div>
              <% end %>
            </div>
            <div class="user-stat">
              <% if user_signed_in? %>
                <%= link_to profile_path(tab: "following"), class: "text-decoration-none" do %>
                  <div class="user-stat-value"><%= current_user.following.count %></div>
                  <div class="user-stat-label">已关注</div>
                <% end %>
              <% else %>
                <div class="user-stat-value">0</div>
                <div class="user-stat-label">已关注</div>
              <% end %>
            </div>
            <div class="user-stat">
              <% if user_signed_in? %>
                <%= link_to profile_path(tab: "followers"), class: "text-decoration-none" do %>
                  <div class="user-stat-value"><%= current_user.followers.count %></div>
                  <div class="user-stat-label">粉丝</div>
                <% end %>
              <% else %>
                <div class="user-stat-value">0</div>
                <div class="user-stat-label">粉丝</div>
              <% end %>
            </div>
            <div class="user-stat">
              <% if user_signed_in? %>
                <div class="user-stat-value"><%= current_user.points %></div>
                <div class="user-stat-label">酷能量</div>
              <% else %>
                <div class="user-stat-value">0</div>
                <div class="user-stat-label">酷能量</div>
              <% end %>
            </div>
          </div>
          <% if user_signed_in? %>
          <div class="text-center px-3">
            <%= link_to new_topic_path, class: "btn btn-primary rounded-3 w-100 mt-3 mb-3" do %>
              <i class="bi bi-plus-lg me-1"></i>创建主题
            <% end %>
          </div>
          <% end %>
        </div>
      </div>

      <!-- 热门节点 -->
      <div class="sidebar-card">
        <div class="card-header d-flex align-items-center">
          <i class="bi bi-fire text-danger me-2"></i>热门节点
        </div>
        <div class="card-body p-0">
          <% @hot_nodes.each do |node| %>
            <a href="<%= node_topics_path(node) %>" class="hot-item d-flex align-items-center">
              <span class="me-2"><%= node.icon.presence || "📄" %></span>
              <span class="text-truncate flex-grow-1"><%= node.name %></span>
              <span class="badge bg-light text-dark rounded-pill flex-shrink-0 ms-1" style="font-size:0.7rem"><%= node.topics_count %></span>
            </a>
          <% end %>
        </div>
      </div>

      <!-- 同节点更多主题 -->
      <% related = @topic.node.topics.recent.where.not(id: @topic.id).limit(5) %>
      <% unless related.empty? %>
      <div class="sidebar-card mt-3">
        <div class="card-header d-flex align-items-center">
          <i class="bi bi-collection me-2 text-primary"></i><%= @topic.node.name %> 更多主题
        </div>
        <div class="card-body p-0">
          <% related.each do |t| %>
            <a href="<%= topic_path(t) %>" class="hot-item d-flex align-items-center">
              <span class="text-truncate flex-grow-1"><%= truncate(t.title, length: 40) %></span>
              <span class="text-muted flex-shrink-0 ms-1" style="font-size:0.7rem"><%= time_ago_in_words(t.created_at) %>前</span>
            </a>
          <% end %>
        </div>
      </div>
      <% end %>
    </div>

  </div>
</div>

