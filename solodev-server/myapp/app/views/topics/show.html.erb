<!-- Poster Template (hidden, used for html2canvas) -->
<div id="poster-wrapper" style="position:fixed;left:-9999px;top:0;z-index:-1;pointer-events:none">
  <div id="poster-container" style="width:390px;background:#fff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,'PingFang SC','Microsoft YaHei',sans-serif;color:#333;line-height:1.6">
    <!-- Header -->
    <div style="padding:16px 20px;border-bottom:3px solid #0d6efd;display:flex;align-items:center;justify-content:space-between">
      <div style="display:flex;align-items:center;gap:8px">
        <i class="bi bi-terminal" style="font-size:1.2rem;color:#0d6efd"></i>
        <span style="font-size:1rem;font-weight:700;color:#0d6efd">SoloDev.Cool</span>
      </div>
      <span style="font-size:0.75rem;color:#999"><%= @topic.node.icon %> <%= @topic.node.name %></span>
    </div>

    <!-- Topic Title -->
    <div style="padding:20px 20px 0">
      <div style="font-size:1.15rem;font-weight:700;color:#1a1a1a;line-height:1.5;word-break:break-word"><%= @topic.title %></div>
      <% if @topic.pinned? %>
        <div style="margin-top:8px;padding:6px 10px;background:#fff3cd;border-radius:6px;font-size:0.75rem;color:#856404">
          <i class="bi bi-pin-angle-fill"></i> 该主题已被管理员置顶
        </div>
      <% end %>
    </div>

    <!-- Author Info -->
    <div style="padding:14px 20px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #f0f0f0">
      <% if @topic.user.has_avatar? %>
        <img src="<%= @topic.user.avatar_data_url %>" style="width:32px;height:32px;border-radius:6px;object-fit:cover" alt="">
      <% else %>
        <div style="width:32px;height:32px;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:0.8rem;background:#6c757d">
          <%= user_initial(@topic.user) %>
        </div>
      <% end %>
      <div style="flex:1">
        <div style="font-size:0.85rem;font-weight:600;color:#333"><%= @topic.user.display_name %></div>
        <div style="font-size:0.72rem;color:#999"><%= @topic.created_at.strftime("%Y-%m-%d %H:%M") %> &middot; <%= @topic.views_count %> 浏览 &middot; <%= @comments.count %> 评论 &middot; <%= @topic.cools_count %> cool</div>
      </div>
    </div>

    <!-- Poll Section -->
    <% if @poll.present? %>
      <div style="margin:14px 20px;padding:14px;border:1px solid #e9ecef;border-radius:8px;background:#fafbfc">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <div style="font-size:0.88rem;font-weight:700;color:#333">
            <i class="bi bi-bar-chart-line" style="color:#0d6efd"></i> 投票
          </div>
          <span style="font-size:0.72rem;color:#999"><i class="bi bi-people"></i> <%= @poll.total_votes %> 人参与</span>
        </div>
        <% if @poll.closed? %>
          <div style="padding:4px 8px;background:#e9ecef;border-radius:4px;font-size:0.72rem;color:#6c757d;margin-bottom:8px">
            <i class="bi bi-lock"></i> 投票已结束
          </div>
        <% end %>
        <% @poll.poll_options.each_with_index do |option, idx| %>
          <% percentage = option.vote_percentage %>
          <div style="margin-bottom:8px;padding:10px;border:1px solid #e9ecef;border-radius:6px;background:#fff">
            <div style="display:flex;align-items:center;margin-bottom:6px">
              <span style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:4px;background:#e9ecef;font-size:0.72rem;font-weight:700;color:#495057;flex-shrink:0;margin-right:8px"><%= ('A'..'Z').to_a[idx] %></span>
              <span style="font-size:0.82rem;color:#333;flex:1;word-break:break-word"><%= option.title %></span>
            </div>
            <div style="display:flex;align-items:center;gap:8px">
              <div style="flex:1;height:6px;background:#e9ecef;border-radius:3px;overflow:hidden">
                <div style="height:100%;width:<%= percentage %>%;background:#0d6efd;border-radius:3px;min-width:<%= percentage > 0 ? '4px' : '0' %>"></div>
              </div>
              <span style="font-size:0.72rem;color:#666;flex-shrink:0;min-width:32px;text-align:right"><%= percentage %>%</span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Topic Content -->
    <div id="poster-topic-content" style="padding:14px 20px;font-size:0.9rem;line-height:1.7;word-break:break-word;color:#333"></div>

    <!-- Comments Section -->
    <% if @comments.present? %>
      <div style="border-top:1px solid #f0f0f0">
        <div style="padding:12px 20px;font-size:0.88rem;font-weight:700;color:#333;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:6px">
          <i class="bi bi-chat-dots" style="color:#999"></i> 评论 (<%= @comments.count %>)
        </div>
        <% @comments.each do |comment| %>
          <div style="padding:12px 20px;border-bottom:1px solid #f5f5f5;display:flex;gap:10px">
            <% if comment.user.has_avatar? %>
              <img src="<%= comment.user.avatar_data_url %>" style="width:28px;height:28px;border-radius:6px;object-fit:cover;flex-shrink:0" alt="">
            <% else %>
              <div style="width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600;font-size:0.7rem;background:#6c757d;flex-shrink:0">
                <%= user_initial(comment.user) %>
              </div>
            <% end %>
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
                <span style="font-size:0.8rem;font-weight:600;color:#333"><%= comment.user.display_name %></span>
                <span style="font-size:0.68rem;color:#bbb"><%= time_ago_in_words(comment.created_at) %>前</span>
                <% tip_total = Tip.total_amount_for(comment) %>
                <% if tip_total > 0 %>
                  <span style="font-size:0.68rem;color:#f59e0b"><i class="bi bi-gift"></i> <%= tip_total %></span>
                <% end %>
              </div>
              <% if comment.parent.present? %>
                <div style="margin-bottom:6px;padding:6px 8px;background:#f8f9fa;border-left:3px solid #0d6efd;border-radius:0 4px 4px 0;font-size:0.75rem">
                  <span style="color:#0d6efd;font-weight:600">@<%= comment.parent.user.display_name %></span>
                  <span style="color:#666;margin-left:4px"><%= truncate(comment.parent.content, length: 100) %></span>
                </div>
              <% end %>
              <div style="font-size:0.82rem;color:#444;line-height:1.6;word-break:break-word"><%= render_mentions(comment.content) %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Footer -->
    <div style="padding:16px 20px;border-top:1px solid #f0f0f0;display:flex;align-items:center;gap:14px">
      <div id="poster-qr-code" style="flex-shrink:0"></div>
      <div>
        <div style="font-size:0.7rem;color:#bbb;margin-bottom:4px">
          来自 SoloDev.Cool 独立开发者社区<br>扫码或访问链接查看更多
        </div>
        <div id="poster-footer-link" style="font-size:0.68rem;color:#0d6efd;word-break:break-all"></div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var raw = document.getElementById('topic-content-raw');
  var rendered = document.getElementById('topic-content-rendered');
  var isSignedIn = <%= user_signed_in? %>;
  if (raw && rendered && typeof marked !== 'undefined') {
    // Pre-process registered-only blocks: convert :::registered-only ... ::: to HTML divs
    var content = raw.value.replace(/:::registered-only\n([\s\S]*?):::/g, function(match, inner) {
      return '<div class="registered-only-block">' + marked.parse(inner.trim()) + '</div>';
    });
    rendered.innerHTML = marked.parse(content);

    // For logged-in users, add a badge to indicate registered-only content
    if (isSignedIn) {
      rendered.querySelectorAll('.registered-only-block').forEach(function(block) {
        var badge = document.createElement('div');
        badge.className = 'registered-only-badge';
        badge.innerHTML = '<i class="bi bi-eye-fill"></i> 仅注册用户可见';
        block.insertBefore(badge, block.firstChild);
      });
    } else {
      rendered.querySelectorAll('.registered-only-block').forEach(function(block) {
        block.innerHTML = '<div class="registered-only-placeholder">' +
          '<div class="registered-only-placeholder-icon"><i class="bi bi-lock-fill"></i></div>' +
          '<div class="registered-only-placeholder-text">此部分内容仅注册用户可见</div>' +
          '<a href="<%= new_user_session_path %>" class="btn btn-sm btn-outline-primary rounded-pill px-3 mt-2">登录查看</a>' +
          '</div>';
      });
    }
    raw.remove();
  }

  document.querySelectorAll('[data-bs-toggle="popover"]').forEach(function(el) {
    new bootstrap.Popover(el);
  });

  // Initialize @mention for new comment input
  var newCommentInput = document.getElementById('new-comment-input');
  if (newCommentInput) {
    initMention(newCommentInput);
  }

  // Initialize @mention for reply forms
  document.querySelectorAll('.reply-form textarea').forEach(function(textarea) {
    initMention(textarea);
  });
});

function toggleReplyForm(btn) {
  var form = btn.closest('.flex-grow-1').querySelector('.reply-form');
  var isVisible = form.style.display !== 'none';
  document.querySelectorAll('.reply-form').forEach(function(f) { f.style.display = 'none'; });
  if (!isVisible) form.style.display = 'block';
}

function cancelReply(btn) {
  btn.closest('.reply-form').style.display = 'none';
}

// Poll vote
function handlePollVote(el, topicId, optionId) {
  if (el.dataset.voted === 'true') return;
  if (!document.querySelector('meta[name="csrf-token"]')) return;

  var token = document.querySelector('meta[name="csrf-token"]').content;

  fetch('/topics/' + topicId + '/poll/vote', {
    method: 'POST',
    headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
    credentials: 'same-origin',
    body: JSON.stringify({ poll_option_id: optionId })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    if (data.success) {
      // Show all bars and percentages
      document.querySelectorAll('.poll-option').forEach(function(opt) {
        opt.dataset.voted = 'true';
        opt.style.cursor = 'default';

        // Remove old bar/meta if exists
        var oldBar = opt.querySelector('.poll-option-bar');
        if (oldBar) oldBar.remove();
        var oldMeta = opt.querySelector('.poll-option-meta');
        if (oldMeta) oldMeta.remove();

        // Remove old check
        var oldCheck = opt.querySelector('.poll-option-check');
        if (oldCheck) oldCheck.remove();
        opt.classList.remove('poll-option-selected');

        // Find matching option data
        var optId = parseInt(opt.dataset.optionId);
        var optData = data.options.find(function(o) { return o.id === optId; });
        if (optData) {
          // Add bar
          var bar = document.createElement('div');
          bar.className = 'poll-option-bar';
          var barFill = document.createElement('div');
          barFill.className = 'poll-option-bar-fill';
          barFill.style.width = optData.percentage + '%';
          bar.appendChild(barFill);
          opt.appendChild(bar);

          // Add meta
          var meta = document.createElement('div');
          meta.className = 'poll-option-meta';
          meta.innerHTML = '<span>' + optData.percentage + '%</span><span>' + optData.votes_count + ' 票</span>';
          opt.appendChild(meta);

          // Highlight selected
          if (optData.id === optionId) {
            opt.classList.add('poll-option-selected');
            var check = document.createElement('i');
            check.className = 'bi bi-check-circle-fill poll-option-check';
            opt.querySelector('.poll-option-label').appendChild(check);
          }
        }
      });

      // Update total votes
      var totalEl = document.getElementById('poll-total-votes');
      if (totalEl) totalEl.textContent = data.total_votes;
    } else {
      alert(data.error || '投票失败');
    }
  })
  .catch(function() {
    alert('投票失败，请重试');
  });
}

// Cool button
document.addEventListener('DOMContentLoaded', function() {
  var coolBtn = document.getElementById('cool-btn');
  if (coolBtn) {
    coolBtn.addEventListener('click', function() {
      var topicId = this.dataset.topicId;
      var isCooled = this.dataset.cooled === 'true';
      var token = document.querySelector('meta[name="csrf-token"]').content;

      fetch('/topics/' + topicId + '/cool', {
        method: isCooled ? 'DELETE' : 'POST',
        headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        document.getElementById('cools-count').textContent = data.cools_count;
        coolBtn.dataset.cooled = data.action === 'cooled' ? 'true' : 'false';
        if (data.action === 'cooled') {
          coolBtn.classList.add('cooled');
        } else {
          coolBtn.classList.remove('cooled');
        }
      });
    });
  }

  // Tip buttons
  document.querySelectorAll('.tip-trigger').forEach(function(btn) {
    btn.addEventListener('click', function() {
      showTipModal(this);
    });
  });

  // Comment cool buttons
  document.querySelectorAll('.comment-cool-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var commentId = this.dataset.commentId;
      var isCooled = this.dataset.cooled === 'true';
      var token = document.querySelector('meta[name="csrf-token"]').content;
      var self = this;

      fetch('/topics/' + this.dataset.topicId + '/comments/' + commentId + '/cool', {
        method: isCooled ? 'DELETE' : 'POST',
        headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
        credentials: 'same-origin'
      })
      .then(function(res) { return res.json(); })
      .then(function(data) {
        self.querySelector('.comment-cools-count').textContent = data.cools_count;
        self.dataset.cooled = data.action === 'cooled' ? 'true' : 'false';
        if (data.action === 'cooled') {
          self.classList.add('cooled');
        } else {
          self.classList.remove('cooled');
        }
      });
    });
  });
});

// Tip modal
var tipModal = null;
function showTipModal(btn) {
  var commentId = btn.dataset.commentId;
  var commentUser = btn.dataset.commentUser;
  var topicId = btn.dataset.topicId;
  var currentPoints = parseInt(btn.dataset.currentPoints);
  var tipTotal = parseInt(btn.dataset.tipTotal);
  var amounts = [10, 20, 30, 50, 100];

  if (tipModal) { tipModal.remove(); }

  var html = '<div class="modal fade" id="tipModal" tabindex="-1">' +
    '<div class="modal-dialog modal-sm modal-dialog-centered">' +
    '<div class="modal-content rounded-3 overflow-hidden border-0 shadow">' +
      '<div class="modal-body p-4 text-center">' +
        '<div class="mb-3"><i class="bi bi-gift-fill text-warning" style="font-size:2rem"></i></div>' +
        '<h6 class="fw-bold mb-1">打赏 ' + commentUser + '</h6>' +
        '<p class="text-muted mb-3" style="font-size:0.78rem">当前酷能量：<strong>' + currentPoints + '</strong></p>' +
        '<div class="d-flex flex-wrap justify-content-center gap-2 mb-3" id="tip-amounts">';
  amounts.forEach(function(a) {
    var disabled = a > currentPoints ? ' disabled' : '';
    var cls = a === 10 ? 'btn-warning text-white' : 'btn-outline-warning';
    html += '<button type="button" class="btn btn-sm rounded-pill tip-amount ' + cls + '"' + disabled + ' data-amount="' + a + '">' + a + '</button>';
  });
  html += '</div>' +
        '<div id="tip-error" class="text-danger small mb-2" style="display:none"></div>' +
        '<div class="d-flex gap-2 justify-content-center">' +
          '<button type="button" class="btn btn-sm btn-light rounded-pill px-3" data-bs-dismiss="modal">取消</button>' +
          '<button type="button" class="btn btn-sm btn-warning text-white rounded-pill px-3" id="tip-confirm-btn" disabled>确认打赏</button>' +
        '</div>' +
      '</div>' +
    '</div></div></div>';

  document.body.insertAdjacentHTML('beforeend', html);
  tipModal = new bootstrap.Modal(document.getElementById('tipModal'));

  var selectedAmount = null;
  var confirmBtn = document.getElementById('tip-confirm-btn');
  var errorEl = document.getElementById('tip-error');

  document.querySelectorAll('.tip-amount').forEach(function(b) {
    b.addEventListener('click', function() {
      if (this.disabled) return;
      document.querySelectorAll('.tip-amount').forEach(function(x) { x.classList.remove('btn-warning', 'text-white'); x.classList.add('btn-outline-warning'); });
      this.classList.remove('btn-outline-warning');
      this.classList.add('btn-warning', 'text-white');
      selectedAmount = parseInt(this.dataset.amount);
      confirmBtn.disabled = false;
      errorEl.style.display = 'none';
    });
  });

  confirmBtn.addEventListener('click', function() {
    if (!selectedAmount) return;
    var token = document.querySelector('meta[name="csrf-token"]').content;
    confirmBtn.disabled = true;
    confirmBtn.textContent = '打赏中...';

    fetch('/topics/' + topicId + '/tips', {
      method: 'POST',
      headers: { 'X-CSRF-Token': token, 'Content-Type': 'application/json' },
      credentials: 'same-origin',
      body: JSON.stringify({ amount: selectedAmount, comment_id: commentId })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      tipModal.hide();
      if (data.success) {
        btn.dataset.currentPoints = data.points;
        btn.dataset.tipTotal = data.tip_total;
        btn.closest('.flex-grow-1').querySelector('.tip-info')?.remove();
        if (data.tip_total > 0) {
          var badge = '<div class="tip-info mt-1"><span class="tip-badge"><i class="bi bi-gift me-1"></i>已获打赏 <strong>' + data.tip_total + '</strong> 酷能量</span></div>';
          btn.closest('.flex-grow-1').querySelector('div[style*="line-height:1.6"]').insertAdjacentHTML('afterend', badge);
        }
      } else {
        errorEl.textContent = data.message;
        errorEl.style.display = 'block';
      }
    })
    .catch(function() {
      confirmBtn.disabled = false;
      confirmBtn.textContent = '确认打赏';
    });
  });

  document.getElementById('tipModal').addEventListener('hidden.bs.modal', function() {
    tipModal = null;
    document.getElementById('tipModal').remove();
  });

  tipModal.show();
}

// @ Mention functionality
function initMention(textarea) {
  let mentionMenu = null;
  let currentQuery = '';
  let matchedUsers = [];
  let selectedIndex = 0;
  let mentionStartPos = 0;

  function createMentionMenu() {
    if (mentionMenu) return;
    mentionMenu = document.createElement('div');
    mentionMenu.className = 'mention-menu';
    mentionMenu.style.cssText = 'position:absolute;z-index:1000;background:#fff;border:1px solid #dee2e6;border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,0.15);max-height:200px;overflow-y:auto;display:none';
    document.body.appendChild(mentionMenu);
  }

  function showMentionMenu(x, y) {
    createMentionMenu();
    mentionMenu.style.display = 'block';
    mentionMenu.style.left = x + 'px';
    mentionMenu.style.top = (y + 24) + 'px';
  }

  function hideMentionMenu() {
    if (mentionMenu) mentionMenu.style.display = 'none';
    currentQuery = '';
    matchedUsers = [];
  }

  function renderMenu() {
    if (!mentionMenu || matchedUsers.length === 0) {
      hideMentionMenu();
      return;
    }
    mentionMenu.innerHTML = matchedUsers.map((u, i) => `
      <div class="mention-item ${i === selectedIndex ? 'selected' : ''}" data-index="${i}" data-username="${u.username}">
        <div style="display:flex;align-items:center;padding:8px 12px;cursor:pointer;${i === selectedIndex ? 'background:#f8f9fa;' : ''}">
          ${u.avatar ? `<img src="${u.avatar}" style="width:24px;height:24px;border-radius:50%;margin-right:8px;">` : `<div style="width:24px;height:24px;border-radius:50%;background:#6366f1;margin-right:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;">${u.username[0].toUpperCase()}</div>`}
          <span style="font-size:14px;color:#333;">${u.username}</span>
        </div>
      </div>
    `).join('');

    mentionMenu.querySelectorAll('.mention-item').forEach((item, index) => {
      item.addEventListener('click', () => insertUser(matchedUsers[index].username));
      item.addEventListener('mouseenter', () => {
        selectedIndex = index;
        renderMenu();
      });
    });
  }

  async function searchUsers(query) {
    const token = document.querySelector('meta[name="csrf-token"]');
    try {
      const res = await fetch('/users/search?q=' + encodeURIComponent(query), {
        headers: { 'X-CSRF-Token': token ? token.content : '' }
      });
      matchedUsers = await res.json();
      selectedIndex = 0;
      renderMenu();
    } catch (e) {
      matchedUsers = [];
      hideMentionMenu();
    }
  }

  function insertUser(username) {
    const textBefore = textarea.value.substring(0, mentionStartPos);
    const textAfter = textarea.value.substring(textarea.selectionEnd);
    textarea.value = textBefore + '@' + username + ' ' + textAfter;
    textarea.selectionStart = textarea.selectionEnd = mentionStartPos + username.length + 2;
    textarea.dispatchEvent(new Event('input'));
    textarea.focus();
    hideMentionMenu();
  }

  textarea.addEventListener('keydown', (e) => {
    if (mentionMenu && mentionMenu.style.display !== 'none') {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = (selectedIndex + 1) % matchedUsers.length;
        renderMenu();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = (selectedIndex - 1 + matchedUsers.length) % matchedUsers.length;
        renderMenu();
      } else if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (matchedUsers[selectedIndex]) {
          insertUser(matchedUsers[selectedIndex].username);
        }
      } else if (e.key === 'Escape') {
        hideMentionMenu();
      }
    }
  });

  textarea.addEventListener('input', (e) => {
    const cursorPos = textarea.selectionStart;
    const textBefore = textarea.value.substring(0, cursorPos);

    const lastAtIndex = textBefore.lastIndexOf('@');
    if (lastAtIndex === -1) {
      hideMentionMenu();
      return;
    }

    const textAfterAt = textBefore.substring(lastAtIndex + 1);
    const spaceAfterAt = textAfterAt.indexOf(' ');
    if (spaceAfterAt !== -1 || textAfterAt.length === 0) {
      hideMentionMenu();
      return;
    }

    if (textAfterAt.length >= 1) {
      mentionStartPos = lastAtIndex;
      const textareaRect = textarea.getBoundingClientRect();
      const line = textarea.value.substring(0, cursorPos).split('\n').length - 1;
      const lineHeight = parseInt(window.getComputedStyle(textarea).lineHeight) || 20;
      const scrollTop = textarea.scrollTop;
      const x = textareaRect.left + 10;
      const y = textareaRect.top + (line + 1) * lineHeight - scrollTop;

      showMentionMenu(x, y);
      if (currentQuery !== textAfterAt) {
        currentQuery = textAfterAt;
        searchUsers(textAfterAt);
      }
    }
  });

  document.addEventListener('click', (e) => {
    if (mentionMenu && !mentionMenu.contains(e.target) && e.target !== textarea) {
      hideMentionMenu();
    }
  });
}
</script>

<script>
function generatePoster() {
  const renderedContent = document.getElementById('topic-content-rendered');
  const posterContent = document.getElementById('poster-topic-content');
  const posterFooter = document.getElementById('poster-footer-link');
  const posterQR = document.getElementById('poster-qr-code');
  if (!renderedContent || !posterContent) return;

  // Fill content
  posterContent.innerHTML = renderedContent.innerHTML;

  // Remove registered-only content from poster
  posterContent.querySelectorAll('.registered-only-block').forEach(function(block) {
    var placeholder = document.createElement('div');
    placeholder.style.cssText = 'padding:10px 14px;background:#f8f9fa;border:1px solid #e9ecef;border-radius:6px;text-align:center;font-size:0.78rem;color:#6c757d';
    placeholder.innerHTML = '<i class="bi bi-lock-fill"></i> 此部分内容仅注册用户可见';
    block.replaceWith(placeholder);
  });

  // Constrain images to fit poster width (390px - 40px padding = 350px)
  posterContent.querySelectorAll('img').forEach(function(img) {
    img.style.maxWidth = '100%';
    img.style.height = 'auto';
  });

  const url = window.location.origin + window.location.pathname;
  posterFooter.textContent = url;

  // Generate QR code
  if (posterQR && typeof qrcode !== 'undefined') {
    posterQR.innerHTML = '';
    const qr = qrcode(0, 'M');
    qr.addData(url);
    qr.make();
    posterQR.innerHTML = qr.createSvgTag({ cellSize: 4, margin: 0, scalable: true });
    const svg = posterQR.querySelector('svg');
    if (svg) {
      svg.style.width = '64px';
      svg.style.height = '64px';
      svg.style.borderRadius = '6px';
    }
  }

  const container = document.getElementById('poster-container');

  html2canvas(container, {
    scale: 2,
    useCORS: true,
    allowTaint: true,
    backgroundColor: '#ffffff',
    width: 390,
    windowWidth: 390,
    logging: false
  }).then(function(canvas) {
    const link = document.createElement('a');
    link.download = '<%= @topic.title.truncate(30).gsub(/[\\\/:*?"<>|]/, '_') %>_长图.png';
    link.href = canvas.toDataURL('image/png');
    link.click();
  }).catch(function(err) {
    console.error('Poster generation failed:', err);
    alert('生成长图失败，请稍后重试');
  });
}
</script>
